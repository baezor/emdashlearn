---
interface Props {
	/* TODO: replace with a real Formspree or ConvertKit endpoint when ready */
	action?: string;
}
const { action = "" } = Astro.props;
---

<section class="waitlist" id="waitlist">
	<div class="waitlist__inner">
		<div class="waitlist__content">
			<p class="waitlist__label">Join the waitlist</p>
			<h2 class="waitlist__title">Be the first to build<br /> with emdashlearn.</h2>
			<p class="waitlist__sub">
				Get notified when emdashlearn enters beta. No spam — just a ping when it's
				ready.
			</p>
		</div>

		<form
			method="POST"
			action={action}
			class="waitlist__form"
			novalidate
			onsubmit="return false;"
		>
			<div class="waitlist__field">
				<label for="email" class="sr-only">Email address</label>
				<div class="waitlist__input-group">
					<input
						type="email"
						id="email"
						name="email"
						placeholder="your@email.com"
						required
						autocomplete="email"
						class="waitlist__input"
					/>
					<button type="submit" class="waitlist__btn">
						Notify me
					</button>
				</div>
			</div>
			<p class="waitlist__fine-print">
				<span>No spam.</span>
				<span>MIT licensed.</span>
				<span>Built in public.</span>
			</p>
		</form>
	</div>
</section>

<style>
	.waitlist {
		padding: var(--space-24) var(--space-8);
		position: relative;
	}

	.waitlist::before {
		content: "";
		position: absolute;
		top: 0;
		left: var(--space-8);
		right: var(--space-8);
		height: 1px;
		background: linear-gradient(
			90deg,
			transparent,
			var(--color-border),
			transparent
		);
	}

	.waitlist__inner {
		max-width: var(--wide-width);
		margin: 0 auto;
		display: grid;
		gap: var(--space-12);
	}

	@media (min-width: 768px) {
		.waitlist__inner {
			grid-template-columns: 1fr 1fr;
			align-items: center;
		}
	}

	.waitlist__label {
		font-family: var(--font-mono);
		font-size: var(--font-size-xs);
		color: var(--color-accent);
		letter-spacing: 0.1em;
		text-transform: uppercase;
		margin-bottom: var(--space-3);
	}

	.waitlist__title {
		font-family: var(--font-display);
		font-size: clamp(1.75rem, 3.5vw, 2.5rem);
		font-weight: 800;
		letter-spacing: -0.03em;
		line-height: 1.1;
		color: var(--color-text);
		margin-bottom: var(--space-4);
	}

	.waitlist__sub {
		font-size: var(--font-size-base);
		color: var(--color-text-secondary);
		line-height: 1.65;
	}

	/* Form */
	.waitlist__form {
		display: flex;
		flex-direction: column;
		gap: var(--space-4);
	}

	.waitlist__field {
		display: flex;
		flex-direction: column;
		gap: var(--space-3);
	}

	.waitlist__input-group {
		display: flex;
		gap: 0;
		border: 1px solid var(--color-border);
		border-radius: var(--radius-md);
		overflow: hidden;
		transition: border-color var(--transition), box-shadow var(--transition);
		background: var(--color-surface);
	}

	.waitlist__input-group:focus-within {
		border-color: var(--color-accent);
		box-shadow: 0 0 0 3px var(--color-accent-glow);
	}

	.waitlist__input {
		flex: 1;
		padding: var(--space-3) var(--space-4);
		background: transparent;
		border: none;
		outline: none;
		color: var(--color-text);
		font-family: var(--font-body);
		font-size: var(--font-size-base);
		min-width: 0;
	}

	.waitlist__input::placeholder {
		color: var(--color-muted);
	}

	.waitlist__btn {
		padding: var(--space-3) var(--space-6);
		background: var(--color-accent);
		border: none;
		color: #000;
		font-family: var(--font-body);
		font-size: var(--font-size-sm);
		font-weight: 600;
		cursor: pointer;
		white-space: nowrap;
		transition: background var(--transition);
		border-left: 1px solid rgba(255, 255, 255, 0.1);
	}

	.waitlist__btn:hover {
		background: var(--color-accent-hover);
	}

	.waitlist__fine-print {
		display: flex;
		flex-wrap: wrap;
		gap: var(--space-4);
		font-family: var(--font-mono);
		font-size: var(--font-size-xs);
		color: var(--color-muted);
		letter-spacing: 0.03em;
	}

	.waitlist__fine-print span::before {
		content: "✓ ";
		color: var(--color-progress);
	}

	@media (min-width: 768px) {
		.waitlist {
			padding: var(--space-24) var(--space-12);
		}

		.waitlist::before {
			left: var(--space-12);
			right: var(--space-12);
		}
	}

	@media (min-width: 1200px) {
		.waitlist {
			padding: var(--space-24) var(--space-20);
		}

		.waitlist::before {
			left: var(--space-20);
			right: var(--space-20);
		}
	}
</style>
